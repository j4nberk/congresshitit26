{
    "name": "mail-hitit",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "main": "electron/main.js",
    "author": "Adem Janberk ERSAN",
    "scripts": {
        "dev:vite": "vite",
        "dev:electron": "cross-env NODE_ENV=development electron .",
        "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
        "build:vite": "vite build",
        "build:electron": "electron-builder",
        "build": "npm run build:vite && npm run build:electron"
    },
    "build": {
        "appId": "com.mailhitit.app",
        "productName": "MailHitit",
        "directories": {
            "output": "dist-app"
        },
        "mac": {
            "target": [
                {
                    "target": "dmg",
                    "arch": ["arm64"]
                }
            ],
            "icon": "electron-icons/macos/icon.icns"
        },
        "win": {
            "target": [
                "nsis",
                "portable"
            ],
            "icon": "electron-icons/windows/icon.ico"
        },
        "linux": {
            "icon": "electron-icons/linux/icons/512x512.png"
        },
        "files": [
            "dist/**/*",
            "electron/**/*",
            "electron-icons/**/*",
            "package.json"
        ]
    },
    "dependencies": {
        "electron-store": "^11.0.2",
        "lucide-react": "^0.575.0",
        "nodemailer": "^6.9.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.0",
        "@vitejs/plugin-react": "^5.1.1",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^40.6.0",
        "electron-builder": "^26.8.1",
        "tailwindcss": "^4.2.0",
        "vite": "^7.3.1"
    }
}
